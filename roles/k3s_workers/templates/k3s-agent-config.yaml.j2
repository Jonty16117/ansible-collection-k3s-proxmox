# /etc/rancher/k3s/config.yaml
# K3s agent configuration
# Generated by Ansible for {{ inventory_hostname }}

# Server URL
server: {{ _server_url | default('https://' + hostvars[groups['control_plane'][0]].ansible_host + ':6443') }}

# Cluster token
token: {{ k3s_workers_token }}

# Node labels
{% if _all_labels | default(k3s_workers_labels + k3s_workers_extra_labels) | length > 0 %}
node-label:
{% for label in _all_labels | default(k3s_workers_labels + k3s_workers_extra_labels) %}
  - {{ label }}
{% endfor %}
{% endif %}

# Node taints
{% if k3s_workers_taints | length > 0 %}
node-taint:
{% for taint in k3s_workers_taints %}
  - {{ taint }}
{% endfor %}
{% endif %}

# Kubelet configuration
kubelet-arg:
  - "feature-gates=GracefulNodeShutdown=true"
  - "shutdown-grace-period=30s"