# /etc/rancher/k3s/config.yaml
# K3s agent configuration
# Generated by Ansible for {{ inventory_hostname }}

# Server URL
server: {{ _server_url | default('https://' + hostvars[groups['control_plane'][0]].ansible_host + ':6443') }}

# Cluster token
token: {{ k3s_workers_token }}

# Node labels
{% set _labels = (k3s_workers_labels | default([])) + (k3s_workers_extra_labels | default([])) %}
{% if _labels | length > 0 %}
node-label:
{% for label in _labels %}
  - {{ label }}
{% endfor %}
{% endif %}

# Kubelet configuration
kubelet-arg:
  - "feature-gates=GracefulNodeShutdown=true"