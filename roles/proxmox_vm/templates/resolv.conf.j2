# /etc/resolv.conf
# Generated by Ansible for {{ inventory_hostname }}
# {{ ansible_date_time.iso8601 | default(lookup('pipe', 'date -Iseconds')) }}

{% for dns_server in k3s_network.dns_servers | default(['1.1.1.1']) %}
nameserver {{ dns_server }}
{% endfor %}

{% if k3s_network.domain is defined %}
search {{ k3s_network.domain }}
{% endif %}

# End of Ansible managed resolv.conf