# /etc/rancher/k3s/config.yaml
# K3s server configuration
# Generated by Ansible for {{ inventory_hostname }}

# Cluster token
token: {{ k3s_control_plane_token }}

# Disable components (for Cilium)
disable:
{% for component in k3s_control_plane_disable_components %}
  - {{ component }}
{% endfor %}

# Disable network policy (Cilium handles this)
disable-network-policy: true

# Use containerd
default-local-storage-path: /var/lib/rancher/k3s/storage

# TLS SANs
tls-san:
  - {{ ansible_host | default(inventory_hostname) }}
{% if k3s_is_first_node %}
  - 127.0.0.1
{% endif %}

# Kubelet configuration
kubelet-arg:
  - "feature-gates=GracefulNodeShutdown=true"
  - "shutdown-grace-period=30s"

# etcd configuration (embedded)
{% if not k3s_is_first_node %}
server: https://{{ hostvars[groups['control_plane'][0]].ansible_host }}:6443
{% endif %}

# Additional arguments
{% if k3s_control_plane_extra_args %}
{{ k3s_control_plane_extra_args }}
{% endif %}