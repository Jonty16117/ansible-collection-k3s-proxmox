# Cilium Helm values
# Generated by Ansible for {{ inventory_hostname }}

# Operator configuration
operator:
  replicas: 1
  resources:
    limits:
      cpu: 500m
{% if k3s_cilium_optimized | bool %}
      memory: 256Mi
    requests:
      cpu: 50m
      memory: 128Mi
{% else %}
      memory: 512Mi
    requests:
      cpu: 100m
      memory: 256Mi
{% endif %}

# Agent resources
resources:
  limits:
    cpu: 1000m
{% if k3s_cilium_optimized | bool %}
    memory: 256Mi
  requests:
    cpu: 100m
    memory: 128Mi
{% else %}
    memory: 512Mi
  requests:
    cpu: 200m
    memory: 256Mi
{% endif %}

# eBPF configuration
bpf:
  masquerade: true

# IPAM configuration
ipam:
  mode: "kubernetes"

# Kube-proxy replacement
kubeProxyReplacement: true

# LoadBalancer configuration
{% if k3s_cilium_lb_pool_start and k3s_cilium_lb_pool_end %}
l2announcements:
  enabled: true

loadBalancer:
  algorithm: maglev
  mode: dsr

bgpControlPlane:
  enabled: false

# LB IPAM
lbIPAM:
  enabled: true
  pools:
    - name: default
      cidrs:
        - cidr: "{{ k3s_cilium_lb_pool_start | ansible.utils.ipaddr('network') }}/28"
{% endif %}

# Hubble configuration
hubble:
  enabled: {{ k3s_cilium_hubble_enabled | bool | lower }}
  relay:
    enabled: {{ k3s_cilium_hubble_enabled | bool | lower }}
  ui:
    enabled: {{ k3s_cilium_hubble_enabled | bool | lower }}

# Direct routing (disable VXLAN if on same L2)
{% if k3s_cilium_direct_routing | bool %}
tunnelProtocol: ""
routingMode: native
autoDirectNodeRoutes: true
{% else %}
tunnelProtocol: vxlan
{% endif %}

# Prometheus metrics
prometheus:
  enabled: false

# Enable IPv6 (optional)
ipv6:
  enabled: false