# Cilium Helm values - Generated by Ansible

# Use node's IP for API server connection during bootstrap
# This avoids chicken-and-egg problem with CNI
k8sServiceHost: "{{ ansible_host | default(inventory_hostname) }}"
k8sServicePort: 6443

operator:
  replicas: 1
  resources:
    limits:
      cpu: 500m
      memory: {{ "256Mi" if k3s_cilium_optimized | bool else "512Mi" }}
    requests:
      cpu: {{ "50m" if k3s_cilium_optimized | bool else "100m" }}
      memory: {{ "128Mi" if k3s_cilium_optimized | bool else "256Mi" }}

resources:
  limits:
    cpu: 1000m
    memory: {{ "256Mi" if k3s_cilium_optimized | bool else "512Mi" }}
  requests:
    cpu: {{ "100m" if k3s_cilium_optimized | bool else "200m" }}
    memory: {{ "128Mi" if k3s_cilium_optimized | bool else "256Mi" }}

bpf:
  masquerade: true

ipam:
  mode: "kubernetes"

kubeProxyReplacement: true

{% if k3s_cilium_l2_enabled | bool %}
l2announcements:
  enabled: true
  externalInterfaces:
    - eth0

loadBalancer:
  algorithm: maglev
  mode: dsr

lbIPAM:
  enabled: true
  pools:
    - name: default
      cidrs:
        - cidr: "{{ k3s_cilium_lb_pool_cidr }}"
{% endif %}

{% if k3s_cilium_hubble_enabled | bool %}
hubble:
  enabled: true
  relay:
    enabled: true
  ui:
    enabled: true
{% endif %}

ipv4NativeRoutingCIDR: "{{ k3s_cluster_cidr }}"
ipv4Masquerade: true
enableIpMasqAgent: false
tunnelProtocol: ""
routingMode: native
autoDirectNodeRoutes: true

{% if k3s_cilium_prometheus_enabled | bool %}
prometheus:
  enabled: true
  port: 9090
{% endif %}

{% if k3s_cilium_bandwidth_manager | bool %}
bandwidthManager:
  enabled: true
{% endif %}

{% if k3s_cilium_egress_gateway | bool %}
egressGateway:
  enabled: true
{% endif %}

ingressController:
  enabled: true
  ingressClassName: cilium
{% if k3s_cilium_hostport_enabled | bool %}
  ingressLBPort: 80
  hostPort:
    enabled: true
{% endif %}

envoy:
  enabled: true