# Cilium Ingress Controller RBAC - Generated by Ansible
# Extends cilium-operator with permissions needed for ingress controller functionality

apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: cilium-operator-ingress-extra
  labels:
    app.kubernetes.io/managed-by: Ansible
    app.kubernetes.io/part-of: cilium
rules:
  - apiGroups:
      - networking.k8s.io
    resources:
      - ingresses
      - ingressclasses
    verbs:
      - get
      - list
      - watch
  - apiGroups:
      - networking.k8s.io
    resources:
      - ingresses/status
    verbs:
      - update
      - patch
  - apiGroups:
      - ""
    resources:
      - services
    verbs:
      - create
      - update
      - patch
      - delete
  - apiGroups:
      - discovery.k8s.io
    resources:
      - endpointslices
    verbs:
      - create
      - update
      - patch
      - delete
      - list
      - watch
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: cilium-operator-ingress-extra
  labels:
    app.kubernetes.io/managed-by: Ansible
    app.kubernetes.io/part-of: cilium
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cilium-operator-ingress-extra
subjects:
  - kind: ServiceAccount
    name: cilium-operator
    namespace: {{ k3s_cilium_namespace }}
