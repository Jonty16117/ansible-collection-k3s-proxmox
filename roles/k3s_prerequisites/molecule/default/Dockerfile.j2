# Dockerfile for Molecule testing on Alpine
# Builds an Ansible-compatible Alpine image

FROM alpine:3.18

# Install Python and required tools for Ansible
RUN apk add --no-cache \
    python3 \
    py3-pip \
    py3-virtualenv \
    openrc \
    sudo \
    bash \
    ca-certificates

# Create ansible user (molecule default)
RUN adduser -D -s /bin/sh ansible && \
    echo "ansible ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Ensure openrc can run in container
RUN mkdir -p /run/openrc && touch /run/openrc/softlevel

CMD ["/sbin/init"]