# /etc/conf.d/zram-init
# Configuration for zRAM (compressed RAM swap)
# Generated by Ansible

# Size of zram device (can be % of RAM or absolute value)
ZRAM_SIZE="{{ zram_size | default('50%') }}"

# Number of zram devices (typically 1 per CPU core)
ZRAM_NUM_DEVICES=1

# Compression algorithm (lzo, lzo-rle, lz4, zstd)
ZRAM_COMP_ALGORITHM=zstd